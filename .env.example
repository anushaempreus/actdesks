# Contact form — Resend (https://resend.com)
# Copy this file to .env.local and fill in your values. Never commit .env.local.

# Your Resend API key (starts with "re_"). Add this to enable the contact form.
RESEND_API_KEY=

# Where enquiries are delivered.
CONTACT_TO_EMAIL=info@actdecks.com.au

# The "from" address. Use a sender on a domain you've verified in Resend.
# Until then, Resend's shared onboarding sender works for testing:
CONTACT_FROM_EMAIL=ACT Decks Website <onboarding@resend.dev>
